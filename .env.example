POSTGRES_DB=purpura
POSTGRES_USER=purpura
POSTGRES_PASSWORD=purpura
DATABASE_URL=postgresql+psycopg://purpura:purpura@localhost:5432/purpura
SESSION_SECRET_KEY=  # generar y poner real en .env
APP_ENV=development

# Opcional. Sin esta key, la evaluación IA de postulaciones cae en
# modo fallback (REVISAR_MANUAL) y deja constancia en el historial.
# La app NO se rompe si no está configurada.
ANTHROPIC_API_KEY=
