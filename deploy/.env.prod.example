# Proyecto PÚRPURA — variables de producción
# Copiar a .env (mismo directorio) y reemplazar valores.
# NUNCA commitear el .env real.

# Postgres
POSTGRES_DB=purpura
POSTGRES_USER=purpura
POSTGRES_PASSWORD=__REEMPLAZAR_CON_RANDOM_32_CHARS__

# Sesiones (NO reutilizar la dev)
SESSION_SECRET_KEY=__REEMPLAZAR_CON_secrets.token_urlsafe(48)__

# SESSION_COOKIE_SECURE=true   # activar cuando se ponga TLS adelante
